# Copy this file to backend/.env before running locally.

# Telegram is optional. Keep polling disabled unless you add a real bot token.
TELEGRAM_BOT_TOKEN=
TELEGRAM_POLLING_ENABLED=false

# Use one or more hosted model providers if available.
OPENAI_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=

# Local Ollama default for proto.ps1. For Docker on Windows/macOS, use http://host.docker.internal:11434.
OLLAMA_BASE_URL=http://localhost:11434

# Local SQLite database. When proto.ps1 runs from backend/, this creates backend/app.db.
DATABASE_URL=sqlite+aiosqlite:///./app.db

# Langfuse is optional. Fill these only if you want traces and per-agent observations.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
LANGFUSE_BASE_URL=

LOG_LEVEL=INFO
